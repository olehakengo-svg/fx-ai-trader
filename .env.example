# ============================================================
# FX AI Trader - 環境変数テンプレート
# ============================================================
# このファイルを `.env` にコピーして値を設定してください
#   cp .env.example .env
#
# 注意: .env ファイルは .gitignore に含まれており、
#       絶対にGitにコミットしないでください
# ============================================================

# ── データベース ──
# ローカル開発: 未設定で OK (カレントディレクトリに demo_trades.db が自動生成)
# Render本番: /var/data/demo_trades.db
# DB_PATH=/var/data/demo_trades.db

# ── OANDA 連携 (オプション) ──
# ローカル開発では設定不要 (デモトレーダーは OANDA なしで独立稼働)
# 本番環境でのみ設定してください
#
# OANDA_TOKEN=your_oanda_api_token_here
# OANDA_ACCOUNT_ID=001-009-XXXXXXXX-XXX
# OANDA_LIVE=true
# OANDA_UNITS=10000

# ── OANDA モード制御 (オプション) ──
# 許可するトレーディングモードをカンマ区切りで指定
# 未設定 = 全モード許可
# OANDA_MODES=daytrade,daytrade_1h,scalp

# ── 外部 API キー (オプション) ──
# MASSIVE_API_KEY=your_massive_market_data_key
# TWELVEDATA_API_KEY=your_twelvedata_key
# ANTHROPIC_API_KEY=your_anthropic_key
