# ── FX AI Trader ローカル開発用環境変数 ──
# このファイルを .env にコピーして値を入力してください:
#   cp .env.example .env
#   nano .env  (または好きなエディタで編集)
#
# 値はRender Dashboard → fx-ai-trader → Environment からコピーしてください

# Massive Market Data API (Polygon) — 最優先データソース
MASSIVE_API_KEY=ここにMassiveのAPIキーを貼り付け

# OANDA Japan — ブローカー接続
OANDA_TOKEN=ここにOANDAのAPIトークンを貼り付け
OANDA_ACCOUNT_ID=ここにOANDAのアカウントIDを貼り付け

# API認証トークン（任意、ローカルでは不要なら空でOK）
API_AUTH_TOKEN=
