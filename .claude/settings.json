{
  "permissions": {
    "defaultMode": "auto"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/hooks/post-edit-check.sh\""
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/hooks/post-edit-wiki.sh\"",
            "statusMessage": "Wiki update detected..."
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/hooks/post-strategy-edit-check.sh\"",
            "statusMessage": "Strategy change check..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/hooks/user-prompt-kb-sync.sh\"",
            "statusMessage": "KB sync..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/hooks/session-end-save.sh\"",
            "statusMessage": "Saving session to KB..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/hooks/session-start.sh\"",
            "statusMessage": "Loading knowledge base (index + unresolved + lessons + daily)..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/hooks/pre-compact.sh\"",
            "statusMessage": "Auto-saving session log..."
          },
          {
            "type": "prompt",
            "prompt": "Context is about to be compacted. Before it happens: 1) Update today's session log (knowledge-base/wiki/sessions/) — fill in Phase descriptions with what you did, update 未解決事項 with current status. 2) Preserve these KB items in the compaction summary: Tier classifications (wiki/index.md), independent audit binding recommendations (wiki/decisions/), active edge hypotheses (wiki/strategies/edge-pipeline.md), unresolved items from latest session log. 3) DECISION候補検出: セッション中に[DECISION: ...]タグがあるか、または戦略のPROMOTE/DEMOTE/停止、パラメータ変更、リスクポリシー変更があった場合、wiki/decisions/に記録すべきか検討し、該当すればページを作成する。 4) LESSON候補検出: セッション中にバグ修正、想定外の結果(BT/Live乖離>15pp)、判断変更、同じ間違いの繰り返しがあった場合、wiki/lessons/に記録すべきか検討し、該当すればページを作成してindex.mdに追加する。",
            "statusMessage": "Preserving knowledge base context..."
          }
        ]
      }
    ]
  }
}
